{
  "name": "unmeet-desktop",
  "version": "0.1.0",
  "description": "UnMeet Desktop — Measure the real cost of your meetings",
  "main": "main.js",
  "scripts": {
    "start": "electron .",
    "build": "electron-builder",
    "build:win": "electron-builder --win --x64"
  },
  "build": {
    "appId": "com.unmeet.desktop",
    "productName": "UnMeet",
    "directories": {
      "output": "release"
    },
    "files": [
      "main.js",
      "preload.js",
      "tracker.js",
      "classifier.js",
      "workspace.js",
      "renderer/**/*",
      "assets/**/*",
      "node_modules/**/*"
    ],
    "win": {
      "target": "portable",
      "icon": "assets/app-icon.png"
    },
    "portable": {
      "artifactName": "UnMeet-Setup-${version}.exe"
    }
  },
  "devDependencies": {
    "electron": "^43.2.0",
    "electron-builder": "^26.15.3"
  }
}
