{
  "name": "unmeet-desktop",
  "version": "0.1.0",
  "description": "UnMeet Desktop — Measure the real cost of your meetings",
  "main": "main.js",
  "scripts": {
    "start": "electron .",
    "build": "electron-builder"
  },
  "build": {
    "appId": "com.unmeet.desktop",
    "productName": "UnMeet",
    "files": [
      "main.js",
      "preload.js",
      "renderer/**/*",
      "assets/**/*"
    ],
    "win": {
      "target": "nsis"
    },
    "mac": {
      "target": "dmg"
    },
    "linux": {
      "target": "AppImage"
    }
  },
  "devDependencies": {
    "electron": "^43.2.0"
  }
}
