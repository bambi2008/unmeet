{
  "manifest_version": 3,
  "name": "UnMeet",
  "version": "0.1.0",
  "description": "Measure the real cost of your meetings. Know which ones to kill.",
  "icons": {
    "16": "icons/icon16.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  },
  "permissions": [
    "storage",
    "tabs",
    "alarms",
    "identity"
  ],
  "host_permissions": [
    "https://meet.google.com/*",
    "https://*.zoom.us/*",
    "https://teams.microsoft.com/*",
    "https://teams.live.com/*",
    "https://*.feishu.cn/*",
    "https://meeting.tencent.com/*",
    "https://*.ringcentral.com/*",
    "https://*.whereby.com/*",
    "https://calendar.google.com/*"
  ],
  "background": {
    "service_worker": "background.js"
  },
  "action": {
    "default_popup": "popup.html",
    "default_title": "UnMeet",
    "default_icon": {
      "16": "icons/icon16.png",
      "48": "icons/icon48.png",
      "128": "icons/icon128.png"
    }
  },
  "options_page": "options.html",
  "content_scripts": [
    {
      "matches": [
        "https://meet.google.com/*",
        "https://*.zoom.us/*",
        "https://teams.microsoft.com/*",
        "https://teams.live.com/*",
        "https://*.feishu.cn/*",
        "https://meeting.tencent.com/*",
        "https://*.ringcentral.com/*",
        "https://*.whereby.com/*"
      ],
      "js": ["content.js"],
      "run_at": "document_idle"
    }
  ]
}
